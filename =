<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Verify OTP – Daily Drape</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      background: #0d0d1a;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Inter', 'Segoe UI', sans-serif;
      overflow: hidden;
      position: relative;
    }

    .bg-orb {
      position: fixed; border-radius: 50%;
      filter: blur(80px); opacity: 0.18;
      animation: floatOrb 8s ease-in-out infinite;
      pointer-events: none;
    }
    .bg-orb-1 { width:500px;height:500px;background:#c77dff;top:-150px;left:-100px;animation-delay:0s; }
    .bg-orb-2 { width:400px;height:400px;background:#ff6b9d;bottom:-100px;right:-80px;animation-delay:-3s; }
    .bg-orb-3 { width:300px;height:300px;background:#7b2ff7;top:40%;left:40%;animation-delay:-5s; }
    @keyframes floatOrb {
      0%,100%{transform:translate(0,0)scale(1)}
      33%    {transform:translate(30px,-40px)scale(1.05)}
      66%    {transform:translate(-20px,20px)scale(0.97)}
    }

    .particles { position:fixed;inset:0;pointer-events:none; }
    .particle {
      position:absolute;width:3px;height:3px;
      background:#c77dff;border-radius:50%;opacity:0;
      animation:particleFly 6s ease-in infinite;
    }
    @keyframes particleFly {
      0%  {opacity:0;transform:translateY(0)scale(1)}
      10% {opacity:0.6}
      90% {opacity:0.2}
      100%{opacity:0;transform:translateY(-120px)scale(0.3)}
    }

    .grid-bg {
      position:fixed;inset:0;pointer-events:none;
      background-image:
        linear-gradient(rgba(199,125,255,0.04) 1px,transparent 1px),
        linear-gradient(90deg,rgba(199,125,255,0.04) 1px,transparent 1px);
      background-size:60px 60px;
      animation:gridPulse 4s ease-in-out infinite;
    }
    @keyframes gridPulse{0%,100%{opacity:0.5}50%{opacity:1}}

    .float-icons{position:fixed;inset:0;pointer-events:none;}
    .float-icon{
      position:absolute;font-size:1.5rem;opacity:0;
      animation:floatIcon 10s ease-in-out infinite;
    }
    @keyframes floatIcon{
      0%  {opacity:0;transform:translateY(20px)rotate(-10deg)}
      15% {opacity:0.25}
      85% {opacity:0.15}
      100%{opacity:0;transform:translateY(-60px)rotate(10deg)}
    }

    .card {
      position:relative;z-index:10;
      background:rgba(255,255,255,0.05);
      backdrop-filter:blur(24px);
      border:1px solid rgba(199,125,255,0.25);
      border-radius:28px;
      padding:52px 44px;
      width:100%;max-width:440px;
      text-align:center;
      box-shadow:0 0 80px rgba(199,125,255,0.08),0 0 0 1px rgba(255,255,255,0.04);
      animation:cardEntrance 0.7s cubic-bezier(0.34,1.56,0.64,1) both;
    }
    @keyframes cardEntrance{
      from{opacity:0;transform:translateY(40px)scale(0.94)}
      to  {opacity:1;transform:translateY(0)scale(1)}
    }

    .logo {
      font-size:2rem;font-weight:800;
      background:linear-gradient(135deg,#c77dff 0%,#ff6b9d 60%,#ffb347 100%);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
      background-size:200% 200%;
      animation:shimmer 3s ease-in-out infinite;
      display:inline-block;margin-bottom:4px;
    }
    @keyframes shimmer{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
    .logo-star{display:inline-block;animation:spinStar 4s linear infinite;margin-right:6px;}
    @keyframes spinStar{
      0%  {transform:rotate(0deg)scale(1)}
      50% {transform:rotate(180deg)scale(1.2)}
      100%{transform:rotate(360deg)scale(1)}
    }

    .card-heading { font-size:1.5rem;font-weight:800;color:#f0eaf8;margin:18px 0 8px; }
    .card-sub     { color:rgba(255,255,255,0.4);font-size:0.84rem;margin-bottom:10px;line-height:1.5; }
    .email-highlight {
      color:#c77dff;font-weight:600;
      background:rgba(199,125,255,0.1);
      padding:2px 10px;border-radius:6px;
      display:inline-block;margin-bottom:28px;font-size:0.85rem;
    }

    .otp-row { display:flex;justify-content:center;gap:10px;margin-bottom:24px; }
    .otp-box {
      width:52px;height:60px;
      background:rgba(255,255,255,0.06);
      border:1.5px solid rgba(199,125,255,0.25);
      border-radius:14px;
      color:#f0eaf8;font-size:1.6rem;font-weight:700;
      text-align:center;outline:none;
      font-family:inherit;
      transition:border-color 0.25s,background 0.25s,box-shadow 0.25s,transform 0.15s;
      caret-color:transparent;
    }
    .otp-box:focus {
      border-color:#c77dff;
      background:rgba(199,125,255,0.1);
      box-shadow:0 0 0 4px rgba(199,125,255,0.15);
      transform:scale(1.08);
    }
    .otp-box.filled  { border-color:rgba(199,125,255,0.6);background:rgba(199,125,255,0.08); }
    .otp-box.error   { border-color:#ff6b9d !important;background:rgba(255,107,157,0.08) !important;animation:shake 0.4s ease; }
    @keyframes shake{
      0%,100%{transform:translateX(0)}
      20%    {transform:translateX(-6px)}
      40%    {transform:translateX(6px)}
      60%    {transform:translateX(-4px)}
      80%    {transform:translateX(4px)}
    }

    .timer-row {
      display:flex;align-items:center;justify-content:center;
      gap:8px;margin-bottom:22px;
      font-size:0.82rem;color:rgba(255,255,255,0.35);
    }
    .timer-badge {
      background:rgba(199,125,255,0.1);border:1px solid rgba(199,125,255,0.2);
      border-radius:8px;padding:3px 10px;
      color:#c77dff;font-weight:700;font-size:0.85rem;min-width:44px;
      transition:color 0.3s;
    }
    .timer-badge.urgent{color:#ff6b9d;border-color:rgba(255,107,157,0.3);}

    .btn {
      width:100%;padding:15px;
      background:linear-gradient(135deg,#c77dff,#ff6b9d);
      border:none;border-radius:14px;
      color:#fff;font-size:1rem;font-weight:700;
      cursor:pointer;position:relative;overflow:hidden;
      font-family:inherit;
      transition:transform 0.15s,box-shadow 0.15s;
      background-size:200% 200%;
      animation:btnGlow 3s ease-in-out infinite;
    }
    @keyframes btnGlow{
      0%,100%{background-position:0% 50%;box-shadow:0 4px 24px rgba(199,125,255,0.3)}
      50%    {background-position:100% 50%;box-shadow:0 4px 32px rgba(255,107,157,0.4)}
    }
    .btn:hover:not(:disabled){transform:translateY(-2px);}
    .btn:active:not(:disabled){transform:translateY(0)scale(0.98);}
    .btn:disabled{opacity:0.6;cursor:default;transform:none;animation:none;}
    .btn-shine{
      position:absolute;inset:0;
      background:linear-gradient(105deg,transparent 40%,rgba(255,255,255,0.18) 50%,transparent 60%);
      transform:translateX(-100%);animation:shine 3s ease-in-out infinite 1s;
    }
    @keyframes shine{0%{transform:translateX(-100%)}30%{transform:translateX(100%)}100%{transform:translateX(100%)}}
    .btn-text{position:relative;z-index:1;}
    .btn.loading .btn-text::after{
      content:'';display:inline-block;
      width:14px;height:14px;
      border:2px solid rgba(255,255,255,0.4);
      border-top-color:#fff;border-radius:50%;
      margin-left:10px;vertical-align:middle;
      animation:spin 0.7s linear infinite;
    }
    @keyframes spin{to{transform:rotate(360deg)}}

    .resend-row{margin-top:18px;font-size:0.8rem;color:rgba(255,255,255,0.3);}
    .resend-btn{
      background:none;border:none;cursor:pointer;
      color:#c77dff;font-weight:600;font-size:0.8rem;
      font-family:inherit;text-decoration:underline;
      transition:opacity 0.2s;padding:0;
    }
    .resend-btn:disabled{opacity:0.35;cursor:default;text-decoration:none;}

    .flash-msg{margin-bottom:16px;padding:10px 14px;border-radius:10px;font-size:0.82rem;font-weight:600;}
    .flash-error  {background:rgba(255,107,157,0.12);border:1px solid rgba(255,107,157,0.3);color:#ff6b9d;}
    .flash-success{background:rgba(199,125,255,0.1);border:1px solid rgba(199,125,255,0.3);color:#c77dff;}

    /* dev OTP hint box */
    .dev-hint{
      margin-bottom:18px;padding:10px 14px;border-radius:10px;
      font-size:0.8rem;background:rgba(255,183,71,0.08);
      border:1px solid rgba(255,183,71,0.25);color:#ffb347;
      display:none;
    }

    .back-link{
      display:block;margin-top:20px;font-size:0.78rem;
      color:rgba(255,255,255,0.3);text-decoration:none;transition:color 0.2s;
    }
    .back-link:hover{color:#c77dff;}
  </style>
</head>
<body>

  <div class="grid-bg"></div>
  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
  <div class="bg-orb bg-orb-3"></div>
  <div class="particles" id="particles"></div>
  <div class="float-icons" id="floatIcons"></div>

  <div class="card">

    <div class="logo"><span class="logo-star">✦</span>Daily Drape</div>

    <div class="card-heading">Check your inbox ✉️</div>
    <div class="card-sub">We sent a 6-digit code to</div>
    <div class="email-highlight">{{ session.get('otp_email', 'your email') }}</div>

    {% with messages = get_flashed_messages(with_categories=true) %}
      {% for category, message in messages %}
        <div class="flash-msg flash-{{ category }}">{{ message }}</div>
      {% endfor %}
    {% endwith %}

    <!-- Dev mode: shows OTP in page so you can test without email -->
    {% if dev_otp %}
    <div class="dev-hint" id="devHint" style="display:block;">
      🛠️ <strong>Dev mode OTP:</strong> {{ dev_otp }}
    </div>
    {% endif %}

    <form method="POST" action="/verify-otp" id="otpForm">
      <div class="otp-row" id="otpRow">
        <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" id="b0" autocomplete="off">
        <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" id="b1" autocomplete="off">
        <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" id="b2" autocomplete="off">
        <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" id="b3" autocomplete="off">
        <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" id="b4" autocomplete="off">
        <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" id="b5" autocomplete="off">
      </div>
      <input type="hidden" name="otp" id="otpHidden">

      <div class="timer-row">
        <span>Code expires in</span>
        <span class="timer-badge" id="timerBadge">10:00</span>
      </div>

      <button type="submit" class="btn" id="verifyBtn" disabled>
        <span class="btn-shine"></span>
        <span class="btn-text">Verify OTP →</span>
      </button>
    </form>

    <div class="resend-row">
      Didn't get it?
      <button class="resend-btn" id="resendBtn" disabled onclick="resendOTP()">Resend OTP</button>
    </div>

    <a href="/login" class="back-link">← Back to login</a>
  </div>

<script>
  /* particles */
  const pc = document.getElementById('particles');
  for (let i = 0; i < 30; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.cssText = `left:${Math.random()*100}%;top:${40+Math.random()*60}%;
      animation-delay:${Math.random()*6}s;animation-duration:${5+Math.random()*4}s;
      opacity:${0.2+Math.random()*0.5};width:${2+Math.random()*3}px;height:${2+Math.random()*3}px;
      background:${Math.random()>0.5?'#c77dff':'#ff6b9d'}`;
    pc.appendChild(p);
  }
  const icons = ['👗','👠','👒','💍','🧥','👜','🧣','💄','👟','🕶️','✨','🌟'];
  const fi = document.getElementById('floatIcons');
  icons.forEach((icon, i) => {
    const el = document.createElement('div');
    el.className = 'float-icon';
    el.textContent = icon;
    el.style.cssText = `left:${5+Math.random()*90}%;top:${20+Math.random()*70}%;
      animation-delay:${i*0.8}s;animation-duration:${8+Math.random()*6}s;
      font-size:${1.2+Math.random()*1.2}rem`;
    fi.appendChild(el);
  });

  /* OTP boxes */
  const boxes = Array.from(document.querySelectorAll('.otp-box'));
  const verifyBtn = document.getElementById('verifyBtn');
  const hidden    = document.getElementById('otpHidden');
  boxes[0].focus();

  boxes.forEach((box, idx) => {
    box.addEventListener('input', e => {
      const val = e.target.value.replace(/\D/g, '');
      box.value = val;
      val ? box.classList.add('filled') : box.classList.remove('filled');
      if (val && idx < 5) boxes[idx + 1].focus();
      syncHidden();
    });
    box.addEventListener('keydown', e => {
      if (e.key === 'Backspace' && !box.value && idx > 0) {
        boxes[idx-1].value = '';
        boxes[idx-1].classList.remove('filled');
        boxes[idx-1].focus();
        syncHidden();
      }
    });
    box.addEventListener('paste', e => {
      e.preventDefault();
      const text = (e.clipboardData||window.clipboardData).getData('text').replace(/\D/g,'').slice(0,6);
      text.split('').forEach((ch, i) => { if(boxes[i]){boxes[i].value=ch;boxes[i].classList.add('filled');} });
      boxes[Math.min(text.length,5)].focus();
      syncHidden();
    });
  });

  function syncHidden() {
    hidden.value = boxes.map(b=>b.value).join('');
    verifyBtn.disabled = hidden.value.length < 6;
  }

  document.getElementById('otpForm').addEventListener('submit', function(e) {
    if (hidden.value.length < 6) { e.preventDefault(); shakeBoxes(); return; }
    verifyBtn.classList.add('loading');
    verifyBtn.querySelector('.btn-text').textContent = 'Verifying';
    verifyBtn.disabled = true;
  });

  function shakeBoxes() {
    boxes.forEach(b => { b.classList.add('error'); setTimeout(()=>b.classList.remove('error'),600); });
  }

  /* countdown */
  let seconds = 10 * 60;
  const badge  = document.getElementById('timerBadge');
  const resend = document.getElementById('resendBtn');
  const ticker = setInterval(() => {
    seconds--;
    if (seconds <= 0) {
      clearInterval(ticker);
      badge.textContent = '0:00'; badge.classList.add('urgent');
      resend.disabled = false;
      verifyBtn.disabled = true;
      verifyBtn.querySelector('.btn-text').textContent = 'Code Expired';
      return;
    }
    if (seconds <= 60) badge.classList.add('urgent');
    const m = Math.floor(seconds/60), s = seconds%60;
    badge.textContent = `${m}:${s.toString().padStart(2,'0')}`;
  }, 1000);

  function resendOTP() {
    resend.disabled = true;
    fetch('/send-otp', {
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body:`email={{ session.get('otp_email','') }}`
    }).then(()=>{
      seconds = 10*60;
      badge.classList.remove('urgent');
      badge.textContent = '10:00';
      boxes.forEach(b=>{b.value='';b.classList.remove('filled','error');});
      boxes[0].focus(); syncHidden();
    }).catch(()=>{ resend.disabled = false; });
  }
</script>
</body>
</html>